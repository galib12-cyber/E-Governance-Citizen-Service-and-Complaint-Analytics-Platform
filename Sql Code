
-- Part 0 : CLEANUP (drop everything if re-running)

BEGIN
FOR t IN (SELECT table_name FROM user_tables WHERE table_name IN (
'FEEDBACK','COMPLAINT_STATUS_HISTORY', 'COMPLAINTS','APPLICATIONS','SERVICES', 'OFFICERS','DEPARTMENTS','CITIZENS'))
LOOP
EXECUTE IMMEDIATE 'DROP TABLE ' || t.table_name || ' CASCADE CONSTRAINTS'; 
END LOOP;

FOR s IN (SELECT sequence_name FROM user_sequences WHERE sequence_name IN (
'SEQ_CITIZEN','SEQ_DEPARTMENT','SEQ_OFFICER', 'SEQ_SERVICE','SEQ_APPLICATION','SEQ_COMPLAINT', 'SEQ_HISTORY','SEQ_FEEDBACK'))
LOOP
EXECUTE IMMEDIATE 'DROP SEQUENCE ' || s.sequence_name; 
END LOOP;
END;
/

-- Part 1 : SEQUENCES (replaces AUTO_INCREMENT)

CREATE SEQUENCE seq_citizen START WITH 1 INCREMENT BY 1 NOCACHE NOCYCLE;
CREATE SEQUENCE seq_department START WITH 1 INCREMENT BY 1 NOCACHE NOCYCLE;
CREATE SEQUENCE seq_officer START WITH 1 INCREMENT BY 1 NOCACHE NOCYCLE;
CREATE SEQUENCE seq_service START WITH 1 INCREMENT BY 1 NOCACHE NOCYCLE;
CREATE SEQUENCE seq_application START WITH 1 INCREMENT BY 1 NOCACHE NOCYCLE;
CREATE SEQUENCE seq_complaint START WITH 1 INCREMENT BY 1 NOCACHE NOCYCLE;
CREATE SEQUENCE seq_history START WITH 1 INCREMENT BY 1 NOCACHE NOCYCLE;
CREATE SEQUENCE seq_feedback START WITH 1 INCREMENT BY 1 NOCACHE NOCYCLE;


-- Part 2 : TABLE CREATION (3NF Normalized)

-- 2.1 CITIZENS
CREATE TABLE Citizens (
citizen_id NUMBER(10) NOT NULL, 
name VARCHAR2(100) NOT NULL,
email VARCHAR2(150) NOT NULL,
phone VARCHAR2(15) NOT NULL,
address VARCHAR2(500) NOT NULL,
password VARCHAR2(255) NOT NULL,
registration_date DATE DEFAULT SYSDATE NOT NULL, 
is_active NUMBER(1) DEFAULT 1 NOT NULL,
CONSTRAINT pk_citizen PRIMARY KEY (citizen_id), 
CONSTRAINT uq_citizen_email UNIQUE (email),
CONSTRAINT chk_citizen_active CHECK (is_active IN (0,1)), 
CONSTRAINT chk_phone CHECK (REGEXP_LIKE(phone, '^[0-9]{10,15}$'))
);

-- 2.2 DEPARTMENTS
CREATE TABLE Departments (
department_id NUMBER(10) NOT NULL, 
department_name VARCHAR2(150) NOT NULL, 
officer_name VARCHAR2(100) NOT NULL, 
contact VARCHAR2(15) NOT NULL,
email VARCHAR2(150),
location VARCHAR2(200),
CONSTRAINT pk_department PRIMARY KEY (department_id), 
CONSTRAINT uq_department_name UNIQUE (department_name)
);

-- 2.3 OFFICERS
CREATE TABLE Officers (
officer_id NUMBER(10) NOT NULL, 
department_id NUMBER(10) NOT NULL, 
name VARCHAR2(100) NOT NULL,
email VARCHAR2(150) NOT NULL, 
password VARCHAR2(255) NOT NULL,
role VARCHAR2(10) DEFAULT 'officer' NOT NULL, 
is_active NUMBER(1) DEFAULT 1 NOT NULL,
CONSTRAINT pk_officer PRIMARY KEY (officer_id), 
CONSTRAINT uq_officer_email UNIQUE (email),
CONSTRAINT chk_officer_role CHECK (role IN ('officer','admin')),
CONSTRAINT chk_officer_active CHECK (is_active IN (0,1)), 
CONSTRAINT fk_officer_dept FOREIGN KEY (department_id) REFERENCES Departments(department_id)
);

-- 2.4 SERVICES
CREATE TABLE Services (
service_id NUMBER(10) NOT NULL, 
department_id NUMBER(10) NOT NULL, 
service_name VARCHAR2(200) NOT NULL, 
description VARCHAR2(1000),
fee NUMBER(10,2) DEFAULT 0 NOT NULL,
duration_days NUMBER(5) DEFAULT 7 NOT NULL, 
is_active NUMBER(1) DEFAULT 1 NOT NULL,
CONSTRAINT pk_service PRIMARY KEY (service_id), 
CONSTRAINT chk_service_fee CHECK (fee >= 0),
CONSTRAINT chk_service_active CHECK (is_active IN (0,1)), 
CONSTRAINT fk_service_dept FOREIGN KEY (department_id) REFERENCES Departments(department_id)
);

-- 2.5 APPLICATIONS
CREATE TABLE Applications ( 
application_id NUMBER(10) NOT NULL, 
citizen_id NUMBER(10) NOT NULL, 
service_id NUMBER(10) NOT NULL,
apply_date DATE DEFAULT SYSDATE NOT NULL,
status VARCHAR2(20) DEFAULT 'pending' NOT NULL, 
notes VARCHAR2(1000),
CONSTRAINT pk_application PRIMARY KEY (application_id), 
CONSTRAINT chk_app_status CHECK (status IN ('pending','processing','approved','rejected')), 
CONSTRAINT fk_app_citizen FOREIGN KEY (citizen_id) REFERENCES Citizens(citizen_id) ON DELETE CASCADE, 
CONSTRAINT fk_app_service FOREIGN KEY (service_id) REFERENCES Services(service_id)
);

-- 2.6 COMPLAINTS
CREATE TABLE Complaints (
complaint_id NUMBER(10) NOT NULL, 
citizen_id NUMBER(10) NOT NULL, 
department_id NUMBER(10) NOT NULL, 
title VARCHAR2(255) NOT NULL,
description CLOB NOT NULL,
priority VARCHAR2(10) DEFAULT 'medium' NOT NULL, 
status VARCHAR2(20) DEFAULT 'submitted' NOT NULL, 
created_date DATE DEFAULT SYSDATE NOT NULL, 
resolved_date DATE,
CONSTRAINT pk_complaint PRIMARY KEY (complaint_id), 
CONSTRAINT chk_comp_priority CHECK (priority IN ('low','medium','high','critical')), 
CONSTRAINT chk_comp_status CHECK (status IN ('submitted','assigned','in_progress','resolved','closed','rejected')), 
CONSTRAINT chk_comp_resolved CHECK (resolved_date IS NULL OR resolved_date >= created_date), 
CONSTRAINT fk_comp_citizen FOREIGN KEY (citizen_id) REFERENCES Citizens(citizen_id) ON DELETE CASCADE, 
CONSTRAINT fk_comp_dept FOREIGN KEY (department_id) REFERENCES Departments(department_id)
);

-- 2.7 COMPLAINT STATUS HISTORY
CREATE TABLE Complaint_Status_History ( 
history_id NUMBER(10) NOT NULL, 
complaint_id NUMBER(10) NOT NULL, 
officer_id NUMBER(10) NOT NULL, 
old_status VARCHAR2(50) NOT NULL, 
new_status VARCHAR2(50) NOT NULL, 
remarks VARCHAR2(1000),
update_time DATE DEFAULT SYSDATE NOT NULL,
CONSTRAINT pk_history PRIMARY KEY (history_id), 
CONSTRAINT fk_hist_complaint FOREIGN KEY (complaint_id) REFERENCES Complaints(complaint_id) ON DELETE CASCADE,
CONSTRAINT fk_hist_officer FOREIGN KEY (officer_id) REFERENCES Officers(officer_id)
);

-- 2.8 FEEDBACK
CREATE TABLE Feedback (
feedback_id NUMBER(10) NOT NULL, 
complaint_id NUMBER(10) NOT NULL, 
citizen_id NUMBER(10) NOT NULL, 
rating NUMBER(1) NOT NULL,
comment VARCHAR2(1000),
feedback_date DATE DEFAULT SYSDATE NOT NULL, 
CONSTRAINT pk_feedback PRIMARY KEY (feedback_id), 
CONSTRAINT uq_feedback_comp UNIQUE (complaint_id), 
CONSTRAINT chk_rating CHECK (rating BETWEEN 1 AND 5), 
CONSTRAINT fk_fb_complaint FOREIGN KEY (complaint_id) REFERENCES Complaints(complaint_id) ON DELETE CASCADE,
CONSTRAINT fk_fb_citizen FOREIGN KEY (citizen_id) REFERENCES Citizens(citizen_id) ON DELETE CASCADE
);


-- Part 3 : AUTO-INCREMENT TRIGGERS

CREATE OR REPLACE TRIGGER trg_ai_citizen 
BEFORE INSERT ON Citizens FOR EACH ROW 
BEGIN
IF :NEW.citizen_id IS NULL THEN
SELECT seq_citizen.NEXTVAL INTO :NEW.citizen_id FROM DUAL; 
END IF;
END;
/

CREATE OR REPLACE TRIGGER trg_ai_department 
BEFORE INSERT ON Departments FOR EACH ROW 
BEGIN
IF :NEW.department_id IS NULL THEN
SELECT seq_department.NEXTVAL INTO :NEW.department_id FROM DUAL; 
END IF;
END;
/

CREATE OR REPLACE TRIGGER trg_ai_officer 
BEFORE INSERT ON Officers FOR EACH ROW 
BEGIN
IF :NEW.officer_id IS NULL THEN
SELECT seq_officer.NEXTVAL INTO :NEW.officer_id FROM DUAL; 
