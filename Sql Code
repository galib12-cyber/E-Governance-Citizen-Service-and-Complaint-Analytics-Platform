/

CREATE OR REPLACE TRIGGER trg_ai_application 
BEFORE INSERT ON Applications FOR EACH ROW 
BEGIN
IF :NEW.application_id IS NULL THEN
SELECT seq_application.NEXTVAL INTO :NEW.application_id FROM DUAL; 
END IF;
END;
/

CREATE OR REPLACE TRIGGER trg_ai_complaint 
BEFORE INSERT ON Complaints FOR EACH ROW 
BEGIN
IF :NEW.complaint_id IS NULL THEN
