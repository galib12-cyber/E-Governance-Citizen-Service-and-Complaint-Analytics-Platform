-- Part 5 : SINGLE-TABLE QUERIES (10)

-- Q1: All active citizens ordered by registration date (latest first) 
SELECT citizen_id, name, email, phone, registration_date
FROM Citizens 
WHERE is_active = 1
ORDER BY registration_date DESC;

-- Q2: Monthly citizen registration count 
SELECT TO_CHAR(registration_date,'YYYY') AS yr,
TO_CHAR(registration_date,'MM') AS mon, 
TO_CHAR(registration_date,'Month') AS month_name, 
COUNT(*) AS registrations
FROM Citizens
GROUP BY TO_CHAR(registration_date,'YYYY'), TO_CHAR(registration_date,'MM'), TO_CHAR(registration_date,'Month')
ORDER BY yr, mon;

-- Q3: Complaint count grouped by status 
SELECT status, COUNT(*) AS total_complaints 
FROM Complaints 
GROUP BY status 
ORDER BY total_complaints DESC;

-- Q4: Unresolved complaints older than 7 days 
SELECT complaint_id, title, priority, status, created_date, 
TRUNC(SYSDATE - created_date) AS days_pending 
FROM Complaints 
WHERE status NOT IN ('resolved','closed') 
AND SYSDATE - created_date > 7 
ORDER BY days_pending DESC;

-- Q5: Active services sorted by fee descending 
SELECT service_id, service_name, fee, duration_days 
FROM Services 
WHERE is_active = 1 
ORDER BY fee DESC;

-- Q6: Complaint count per priority level 
SELECT priority, COUNT(*) AS total 
FROM Complaints 
GROUP BY priority 
ORDER BY DECODE(priority,'critical',1,'high',2,'medium',3,'low',4);

-- Q7: Feedback details sorted by rating descending
SELECT feedback_id, complaint_id, rating, comment, feedback_date 
FROM Feedback 
ORDER BY rating DESC;

-- Q8: Active officers sorted by role then name 
SELECT officer_id, name, email, role
FROM Officers 
WHERE is_active = 1 
ORDER BY role DESC, name;

-- Q9: Rejected applications in the last 90 days 
SELECT application_id, citizen_id, service_id, apply_date, notes 
FROM Applications 
WHERE status = 'rejected' 
AND apply_date >= SYSDATE - 90;

-- Q10: Average resolution time in hours for resolved complaints 
SELECT ROUND(AVG((resolved_date - created_date) * 24), 2) 
AS avg_resolution_hours 
FROM Complaints 
WHERE status = 'resolved' 
AND resolved_date IS NOT NULL;


-- Part 6 : MULTI-TABLE JOIN QUERIES (5)

-- J1: Full complaint report with citizen name and department 
SELECT c.complaint_id,
ci.name AS citizen_name, 
d.department_name,
c.title, c.priority, c.status, c.created_date, c.resolved_date 
FROM Complaints c 
JOIN Citizens ci ON ci.citizen_id = c.citizen_id 
JOIN Departments d ON d.department_id = c.department_id 
ORDER BY c.created_date DESC;

-- J2: Service applications with citizen, service and department info 
SELECT a.application_id,
ci.name AS citizen_name, 
s.service_name,
d.department_name, 
a.apply_date, a.status
FROM Applications a 
JOIN Citizens ci ON ci.citizen_id = a.citizen_id 
JOIN Services s ON s.service_id = a.service_id 
JOIN Departments d ON d.department_id = s.department_id 
ORDER BY a.apply_date DESC;

-- J3: Department-wise complaint statistics 
SELECT d.department_name,
COUNT(c.complaint_id) AS total_complaints,
SUM(CASE WHEN c.status = 'resolved' THEN 1 ELSE 0 END) AS resolved,
SUM(CASE WHEN c.status NOT IN ('resolved','closed') THEN 1 ELSE 0 END) AS pending,
ROUND(AVG((c.resolved_date - c.created_date)*24), 1) AS avg_resolution_hrs 
FROM Departments d 
LEFT JOIN Complaints c ON c.department_id = d.department_id 
GROUP BY d.department_id, d.department_name 
ORDER BY total_complaints DESC;

-- J4: Complaint history with officer name and remarks 
SELECT csh.history_id,
c.title AS complaint,
o.name AS updated_by, 
csh.old_status, csh.new_status, csh.remarks, csh.update_time
FROM Complaint_Status_History csh
JOIN Complaints c ON c.complaint_id = csh.complaint_id 
JOIN Officers o ON o.officer_id = csh.officer_id 
ORDER BY csh.update_time DESC;

-- J5: Citizen satisfaction report 
SELECT f.feedback_id,
ci.name AS citizen, 
d.department_name,
c.title AS complaint_title,
f.rating, f.comment, f.feedback_date
FROM Feedback f
JOIN Complaints c ON c.complaint_id = f.complaint_id 
JOIN Citizens ci ON ci.citizen_id = f.citizen_id 
JOIN Departments d ON d.department_id = c.department_id 
ORDER BY f.rating DESC;


-- Part 7 : SUBQUERIES (all types)

-- SQ1: Scalar subquery – citizens with more complaints than average 
SELECT name, email,
(SELECT COUNT(*) FROM Complaints WHERE citizen_id = c.citizen_id) AS my_complaints
FROM Citizens c
WHERE (SELECT COUNT(*) FROM Complaints WHERE citizen_id = c.citizen_id)
> (SELECT AVG(cnt) FROM
(SELECT COUNT(*) cnt FROM Complaints GROUP BY citizen_id));

-- SQ2: IN subquery – complaints in departments with more than 1 complaint 
SELECT complaint_id, title, status
FROM Complaints
WHERE department_id IN (SELECT department_id FROM Complaints
GROUP BY department_id HAVING COUNT(*) > 1);

-- SQ3: NOT IN subquery – citizens who never submitted a complaint 
SELECT citizen_id, name, email
FROM Citizens
WHERE citizen_id NOT IN (
SELECT DISTINCT citizen_id FROM Complaints
);

-- SQ4: EXISTS subquery – departments with at least one unresolved complaint 
SELECT department_id, department_name
FROM Departments d 
WHERE EXISTS (
SELECT 1 FROM Complaints c
WHERE c.department_id = d.department_id
AND c.status NOT IN ('resolved','closed')
);

-- SQ5: Correlated subquery – each complaint with its status-change count 
SELECT complaint_id, title, status,
(SELECT COUNT(*) FROM Complaint_Status_History h
WHERE h.complaint_id = c.complaint_id) AS status_changes 
FROM Complaints c
ORDER BY status_changes DESC;

-- SQ6: Derived table (inline view) – department with highest complaints 
SELECT department_name, total
FROM (
SELECT d.department_name, COUNT(c.complaint_id) AS total 
FROM Departments d
JOIN Complaints c ON c.department_id = d.department_id 
GROUP BY d.department_id, d.department_name
) dept_stats 
WHERE total = (
SELECT MAX(cnt) FROM
(SELECT COUNT(*) cnt FROM Complaints GROUP BY department_id)
);

-- SQ7: Subquery with ALL – non-low complaints after all low-priority ones 
SELECT complaint_id, title, priority
FROM Complaints
WHERE priority != 'low' AND complaint_id > ALL (
SELECT complaint_id FROM Complaints WHERE priority = 'low'
);

-- SQ8: Subquery for latest feedback date
SELECT complaint_id, citizen_id, rating, comment 
FROM Feedback
WHERE feedback_date = (
SELECT MAX(f2.feedback_date) FROM Feedback f2 
WHERE f2.complaint_id = Feedback.complaint_id
);


