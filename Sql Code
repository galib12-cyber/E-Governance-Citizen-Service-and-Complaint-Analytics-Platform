-- Part 9 : STORED PROCEDURES (PL/SQL)

-- SP1: Submit a new complaint
CREATE OR REPLACE PROCEDURE sp_submit_complaint ( 
p_citizen_id IN NUMBER,
p_dept_id IN NUMBER,
p_title IN VARCHAR2, 
p_description IN VARCHAR2, 
p_priority IN VARCHAR2, 
p_complaint_id OUT NUMBER
) AS 
BEGIN
INSERT INTO Complaints
(citizen_id, department_id, title, description, priority, status, created_date) 
VALUES
(p_citizen_id, p_dept_id, p_title, p_description, p_priority, 'submitted', SYSDATE)
RETURNING complaint_id INTO p_complaint_id; 
COMMIT;
DBMS_OUTPUT.PUT_LINE('New complaint ID: ' || p_complaint_id); 
END sp_submit_complaint;
/

-- SP2: Update complaint status with automatic history logging 
CREATE OR REPLACE PROCEDURE sp_update_complaint_status (
p_complaint_id IN NUMBER, 
p_officer_id IN NUMBER, 
p_new_status IN VARCHAR2, 
p_remarks IN VARCHAR2
) AS
v_old_status VARCHAR2(50); 
BEGIN
SELECT status INTO v_old_status FROM Complaints
WHERE complaint_id = p_complaint_id;

UPDATE Complaints
SET status = p_new_status, 
resolved_date = CASE
WHEN p_new_status = 'resolved' THEN SYSDATE 
ELSE resolved_date
END
WHERE complaint_id = p_complaint_id;

INSERT INTO Complaint_Status_History
(complaint_id, officer_id, old_status, new_status, remarks, update_time) 
VALUES
(p_complaint_id, p_officer_id, v_old_status, p_new_status, p_remarks, SYSDATE);

COMMIT;
DBMS_OUTPUT.PUT_LINE('Status updated: ' || v_old_status || ' -> ' || p_new_status);

EXCEPTION
WHEN NO_DATA_FOUND THEN
DBMS_OUTPUT.PUT_LINE('ERROR: Complaint ID ' || p_complaint_id || ' not found.');
WHEN OTHERS THEN 
ROLLBACK;
DBMS_OUTPUT.PUT_LINE('ERROR: ' || SQLERRM);
END sp_update_complaint_status;
/

-- SP3: Department performance report (prints via DBMS_OUTPUT) 
CREATE OR REPLACE PROCEDURE sp_dept_performance_report AS
CURSOR c_dept IS
SELECT d.department_name,
COUNT(c.complaint_id) AS total,
SUM(CASE WHEN c.status='resolved' THEN 1 ELSE 0 END) AS resolved,
SUM(CASE WHEN c.status NOT IN('resolved','closed') THEN 1 ELSE 0 END) AS open_cnt,
ROUND(AVG((c.resolved_date - c.created_date)*24), 1) AS avg_hrs
FROM Departments d
LEFT JOIN Complaints c ON c.department_id = d.department_id 
GROUP BY d.department_id, d.department_name
ORDER BY total DESC;

BEGIN
DBMS_OUTPUT.PUT_LINE(RPAD('Department',35) || LPAD('Total',7)
|| LPAD('Resolved',10) || LPAD('Open',7) || LPAD('Avg Hrs',9)); 
DBMS_OUTPUT.PUT_LINE(RPAD('-',68,'-'));
FOR r IN c_dept LOOP 
DBMS_OUTPUT.PUT_LINE(
RPAD(r.department_name,35)
|| LPAD(NVL(TO_CHAR(r.total),'0'),7)
|| LPAD(NVL(TO_CHAR(r.resolved),'0'),10)
|| LPAD(NVL(TO_CHAR(r.open_cnt),'0'),7)
|| LPAD(NVL(TO_CHAR(r.avg_hrs),'N/A'),9)); 
END LOOP;
END sp_dept_performance_report;
/


-- Part 10 : FUNCTIONS (PL/SQL)

-- FN1: Total complaints for a given citizen
CREATE OR REPLACE FUNCTION fn_citizen_complaint_count ( 
p_citizen_id IN NUMBER
) RETURN NUMBER IS
v_count NUMBER; 
BEGIN
SELECT COUNT(*) INTO v_count FROM Complaints
WHERE citizen_id = p_citizen_id; 
RETURN v_count;
END fn_citizen_complaint_count;
/

-- FN2: Resolution time in hours (-1 if not yet resolved) 
CREATE OR REPLACE FUNCTION fn_resolution_hours (
p_complaint_id IN NUMBER
) RETURN NUMBER IS
v_created DATE; 
v_resolved DATE;
BEGIN
SELECT created_date, resolved_date INTO v_created, v_resolved
FROM Complaints
WHERE complaint_id = p_complaint_id;

IF v_resolved IS NULL THEN 
RETURN -1;
END IF;
RETURN ROUND((v_resolved - v_created) * 24, 2); 
EXCEPTION
WHEN NO_DATA_FOUND THEN 
RETURN -2;
END fn_resolution_hours;
/

-- FN3: Human-readable status label
CREATE OR REPLACE FUNCTION fn_status_label ( 
p_status IN VARCHAR2
) RETURN VARCHAR2 IS 
BEGIN
RETURN CASE p_status
WHEN 'submitted' THEN '[SUBMITTED] Submitted' 
WHEN 'assigned' THEN '[ASSIGNED] Assigned' 
WHEN 'in_progress' THEN '[PROGRESS] In Progress' 
WHEN 'resolved' THEN '[RESOLVED] Resolved' 
WHEN 'closed' THEN '[CLOSED] Closed'
WHEN 'rejected' THEN '[REJECTED] Rejected' 
ELSE '[UNKNOWN] ' || p_status
END;
END fn_status_label;
/


-- Part 11 : TRIGGERS (Business-Logic)

-- T3: BEFORE INSERT on Complaints
-- Auto-escalate priority to 'critical' for emergency keywords 
CREATE OR REPLACE TRIGGER trg_complaint_priority_check
BEFORE INSERT ON Complaints FOR EACH ROW
BEGIN
IF LOWER(:NEW.title) LIKE '%fire%'
OR LOWER(:NEW.title) LIKE '%explosion%' 
OR LOWER(:NEW.title) LIKE '%flood%'
OR LOWER(:NEW.title) LIKE '%collapse%' THEN
:NEW.priority := 'critical'; 
END IF;
END trg_complaint_priority_check;
/

-- T4: BEFORE UPDATE on Complaints
-- Automatically set resolved_date when status changes to 'resolved' 
CREATE OR REPLACE TRIGGER trg_set_resolved_date
BEFORE UPDATE OF status ON Complaints FOR EACH ROW
BEGIN
IF :NEW.status = 'resolved' AND :OLD.status != 'resolved' THEN
:NEW.resolved_date := SYSDATE; 
END IF;
END trg_set_resolved_date;
/

-- T5: AFTER INSERT on Feedback
-- Close the complaint once citizen submits feedback on a resolved case 
CREATE OR REPLACE TRIGGER trg_feedback_audit
AFTER INSERT ON Feedback FOR EACH ROW
BEGIN
UPDATE Complaints
SET status = 'closed'
WHERE complaint_id = :NEW.complaint_id AND status = 'resolved';
END trg_feedback_audit;
/


