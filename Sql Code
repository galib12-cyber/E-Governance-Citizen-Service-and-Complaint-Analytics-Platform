END IF;
END;
/

CREATE OR REPLACE TRIGGER trg_ai_history
BEFORE INSERT ON Complaint_Status_History FOR EACH ROW 
BEGIN
IF :NEW.history_id IS NULL THEN
SELECT seq_history.NEXTVAL INTO :NEW.history_id FROM DUAL;
END IF; 
END;
/

CREATE OR REPLACE TRIGGER trg_ai_feedback 
BEFORE INSERT ON Feedback FOR EACH ROW 
